---
import BaseHead from "$components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION, BASE_PATH } from "$consts";
import { getCollection } from "astro:content";
import PostGrid from "$components/PostGrid.tsx";
const posts = (await getCollection("blog"))
  .map((post) => {
    const displayDate = post.data.updatedDate ?? post.data.date;
    const dateMs =
      displayDate instanceof Date
        ? displayDate.valueOf()
        : new Date(displayDate as unknown as string).valueOf();
    return {
      id: post.id,
      title: post.data.title,
      date: displayDate,
      dateMs,
      tags: post.data.tags ?? [],
    };
  })
  .sort((a, b) => b.dateMs - a.dateMs);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }
      h1 {
        margin: 0 0 0.2em 0;
        font-size: 3.2rem;
        color: #c4874a;
        text-align: center;
      }
      p.lead {
        margin: 0 0 2rem 0;
        color: #7a5540;
        font-size: 1.05rem;
        letter-spacing: 0.01em;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{SITE_TITLE}</h1>
      <p class="lead">{SITE_DESCRIPTION}</p>
      <PostGrid client:load posts={posts} basePath={BASE_PATH} />
    </main>
  </body>
</html>
