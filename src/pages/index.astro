---
import BaseHead from "$components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION, BASE_PATH } from "$consts";
import { getCollection } from "astro:content";
import { extractPreview } from "../utils";
import PostGrid from "$components/PostGrid.astro";

// Extract the shared style block once (identical across all posts)
let sharedStyles = "";
try {
  const sample = readFileSync(resolve("html", "agency", "index.html"), "utf-8");
  sharedStyles = [...sample.matchAll(/<style[\s\S]*?<\/style>/gi)]
    .map(m => m[0]).join("\n");
} catch {}

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

const posts = (await getCollection("blog"))
  .map((post) => {
    const displayDate = post.data.updatedDate ?? post.data.date;
    const dateMs =
      displayDate instanceof Date
        ? displayDate.valueOf()
        : new Date(displayDate as unknown as string).valueOf();
    return {
      id: post.id,
      title: post.data.title,
      date: displayDate,
      dateMs,
      tags: post.data.tags ?? [],
      preview: extractPreview(post.id),
    };
  })
  .sort((a, b) => b.dateMs - a.dateMs);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <Fragment set:html={sharedStyles} />
    <style>
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }
      h1 {
        margin: 0 0 0.2em 0;
        font-size: 3.2rem;
        color: #c4874a;
        text-align: center;
      }
      p.lead {
        margin: 0 0 2rem 0;
        color: #7a5540;
        font-size: 1.05rem;
        letter-spacing: 0.01em;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{SITE_TITLE}</h1>
      <p class="lead">{SITE_DESCRIPTION}</p>
      <PostGrid posts={posts} basePath={BASE_PATH} />
    </main>
  </body>
</html>
