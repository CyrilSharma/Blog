---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "$styles/global.css";
import { SITE_TITLE } from "$consts";
import { BASE_PATH } from "$consts";
import crimsonPro400 from "@fontsource/crimson-pro/files/crimson-pro-latin-400-normal.woff2?url";
import crimsonPro400i from "@fontsource/crimson-pro/files/crimson-pro-latin-400-italic.woff2?url";
import crimsonPro600 from "@fontsource/crimson-pro/files/crimson-pro-latin-600-normal.woff2?url";
import crimsonPro700 from "@fontsource/crimson-pro/files/crimson-pro-latin-700-normal.woff2?url";
import crimsonPro700i from "@fontsource/crimson-pro/files/crimson-pro-latin-700-italic.woff2?url";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = "/blog-placeholder-1.jpg" } = Astro.props;
---

<!-- Font Preloads -->
<link rel="preload" as="font" type="font/woff2" href={crimsonPro400} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={crimsonPro400i} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={crimsonPro600} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={crimsonPro700} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={crimsonPro700i} crossorigin="anonymous" />

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={`${BASE_PATH}/favicon.svg`}/>
<link rel="sitemap" href={`${BASE_PATH}/sitemap-index.xml`}/>
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />


<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<script>
  if (import.meta.hot) {
    import.meta.hot.on("typst-navigate", ({ slug }: { slug: string }) => {
      const target = `${import.meta.env.BASE_URL}/${slug}/`;
      if (!window.location.pathname.endsWith(`/${slug}/`)) {
        window.location.href = target;
      }
    });
  }
</script>
